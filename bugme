#!/bin/bash

IMAGE="ghcr.io/ricardobranco777/bugme"

DOCKER=$(command -v docker)
PODMAN=$(command -v podman)

# We need unprivileged user namespaces for rootless containers
if unshare -U true >/dev/null 2>&1; then
	SUDO=
else
	SUDO=${SUDO:-$(command -v sudo)}
fi

# Use Docker if unprivileged user namespaces are disabled and
# the socket exists, otherwise use podman if available
if [ -z "$RUNTIME" ]; then
	if [ -n "$SUDO" ] && [ -S /var/run/docker.sock ]; then
		RUNTIME=$DOCKER
	else
		RUNTIME=${PODMAN:-$DOCKER}
	fi
fi

# Do not use sudo if we're in docker group
if [[ -n "$SUDO" && $RUNTIME =~ docker ]] && id -Gn | grep -qw docker; then
	SUDO=
fi

opts=(
	--cap-drop=ALL
	--read-only
	--rm
	--security-opt=no-new-privileges
	--user "$(id -u):$(id -g)"
)

if [ "$1" = "--version" ] ; then
	latest=$(curl -s https://api.github.com/repos/ricardobranco777/bugme/tags | jq -Mr '.[0].name')
	if [ "${latest#v}" != "$($SUDO "$RUNTIME" run "${opts[@]}" "$IMAGE" --version | awk '{ print $2 }')" ] ; then
		echo "Latest version available: $latest" >&2
	fi
fi

if [ -n "$SUDO" ]; then
	SUDO="$SUDO --preserve-env=DEBUG"
fi

exec $SUDO "$RUNTIME" run "${opts[@]}" -e DEBUG -v $HOME/creds.json:/creds.json:ro,z "$IMAGE" "$@"
